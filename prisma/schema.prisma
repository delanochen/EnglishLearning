  revisions          WritingSubmission[] @relation("WritingVersions")
  feedback           WritingFeedback?

  @@unique([assignmentId, learnerProfileId, version])
}

model WritingFeedback {
  id               String            @id @default(uuid()) @db.Uuid
  submissionId     String            @unique @db.Uuid
  grammarScore     Float
  spellingScore    Float             @default(0)
  vocabularyScore  Float
  structureScore   Float
