  lesson    ScenarioLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, sequence])
}

model ScenarioExercise {
  id          String         @id @default(uuid()) @db.Uuid
  lessonId    String         @db.Uuid
  type        QuestionType
  prompt      String
  answerKey   String
  options     Json?
  explanation String?
  order       Int
  lesson      ScenarioLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, order])
}

model VideoLesson {
  id               String         @id @default(uuid()) @db.Uuid
  scenarioLessonId String         @unique @db.Uuid
  title            String
  timeline         Json
  durationSeconds  Int
  status           ContentStatus  @default(PUBLISHED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  scenarioLesson   ScenarioLesson @relation(fields: [scenarioLessonId], references: [id], onDelete: Cascade)
}

model ScenarioProgress {
  id               String         @id @default(uuid()) @db.Uuid
