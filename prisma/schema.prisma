  vocabulary         ScenarioVocabulary[]

  @@unique([category, title, version])
  @@index([category, level, status])
}

model ScenarioVocabulary {
  id        String         @id @default(uuid()) @db.Uuid
  lessonId  String         @db.Uuid
  word      String
  meaningZh String
  example   String?
  order     Int
  lesson    ScenarioLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, word])
  @@unique([lessonId, order])
}

model ScenarioDialogue {
  id        String         @id @default(uuid()) @db.Uuid
  lessonId  String         @db.Uuid
