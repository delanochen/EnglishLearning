generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum FamilyMemberType {
  OWNER
  PARENT
  LEARNER
  CHILD
}

enum MemberStatus {
  ACTIVE
  INVITED
  ARCHIVED
}

enum RoleScope {
  SYSTEM
  FAMILY
}

enum AgeBand {
  CHILD
  TEEN
  ADULT
  SENIOR
}

enum CefrLevel {
  PRE_A1
  A1
  A2
  B1
  B2
  C1
}

enum OnboardingStatus {
  PROFILE_PENDING
  PLACEMENT_PENDING
  READY
}

enum AIProviderType {
  OPENAI
  OPENROUTER
  GEMINI
  OPENAI_COMPATIBLE
  OLLAMA
}

enum AIModelStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  UNAVAILABLE
}

enum AIUsagePurpose {
  TUTOR
  VOCABULARY
  READING
  QUIZ
  GRAMMAR
  WRITING
  LEARNING_PLAN
  TRANSLATION
  SPEECH_RECOGNITION
  TTS
  IMAGE_GENERATION
  VIDEO_GENERATION
}

enum AIRequestStatus {
  SUCCESS
  FAILED
}

enum TeacherStyle {
  GENTLE
  STRICT
  CHILD
  ACADEMIC
  US_LIFE
  WORKPLACE
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum VocabularyState {
  NEW
  LEARNING
  REVIEW
  MASTERED
}

enum DailyTaskType {
  VOCABULARY
  READING
  LISTENING
  SPEAKING
  AI_TUTOR
  GRAMMAR
  WRITING
  QUIZ
}

enum DailyTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  VOCABULARY
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  locale        String         @default("zh-CN")
  status        UserStatus     @default(ACTIVE)
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  familyMembers FamilyMember[]
  ownedFamilies Family[]       @relation("FamilyOwner")
  roles         UserRole[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  loginAttempts LoginAttempt[]

  @@index([status, deletedAt])
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Family {
  id                 String         @id @default(uuid()) @db.Uuid
  name               String
  timezone           String         @default("America/Chicago")
  locale             String         @default("zh-CN")
  leaderboardEnabled Boolean        @default(false)
  ownerUserId        String         @db.Uuid
  deletedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  owner              User           @relation("FamilyOwner", fields: [ownerUserId], references: [id])
  members            FamilyMember[]
  userRoles          UserRole[]
  auditLogs          AuditLog[]

  @@index([ownerUserId, deletedAt])
}

model FamilyMember {
  id             String           @id @default(uuid()) @db.Uuid
  familyId       String           @db.Uuid
  userId         String?          @db.Uuid
  displayName    String
  nickname       String?
  memberType     FamilyMemberType
  status         MemberStatus     @default(ACTIVE)
  joinedAt       DateTime         @default(now())
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  family         Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id])
  learnerProfile LearnerProfile?

  @@unique([familyId, userId])
  @@index([familyId, status, deletedAt])
  @@index([userId])
}

model LearnerProfile {
  id                 String                   @id @default(uuid()) @db.Uuid
  familyMemberId     String                   @unique @db.Uuid
  ageBand            AgeBand
  cefrLevel          CefrLevel?
  goals              String[]
  dailyMinutes       Int                      @default(20)
  interests          String[]
  weakAreas          String[]
  totalXp            Int                      @default(0)
  supportLanguage    String                   @default("zh-CN")
  onboardingStatus   OnboardingStatus         @default(PLACEMENT_PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  familyMember       FamilyMember             @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  conversations      AIConversation[]
  vocabularyProgress UserVocabularyProgress[]
  readingProgress    ReadingProgress[]
  dailyTasks         DailyTask[]
  activities         LearningActivity[]
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  scope       RoleScope
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  familyId  String?  @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  family    Family?  @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, familyId])
  @@index([userId, familyId])
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String?  @db.Uuid
  familyId     String?  @db.Uuid
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ipHash       String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  family       Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([familyId, createdAt])
}

model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  namespace   String
  key         String
  value       Json
  isSensitive Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([namespace, key])
}

model LoginAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  emailHash  String
  ipHash     String
  successful Boolean
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([emailHash, ipHash, createdAt])
}

model AIProvider {
  id                  String         @id @default(uuid()) @db.Uuid
  name                String         @unique
  type                AIProviderType
  baseUrl             String
  encryptedApiKey     String?
  apiKeyIv            String?
  apiKeyAuthTag       String?
  keyVersion          Int            @default(1)
  enabled             Boolean        @default(true)
  priority            Int            @default(100)
  timeoutMs           Int            @default(30000)
  notes               String?
  lastConnectionAt    DateTime?
  lastConnectionOk    Boolean?
  lastConnectionMs    Int?
  lastConnectionError String?
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  models              AIModel[]
  requestLogs         AIRequestLog[]

  @@index([enabled, priority, deletedAt])
}

model AIModel {
  id            String              @id @default(uuid()) @db.Uuid
  providerId    String              @db.Uuid
  name          String
  displayName   String
  capabilities  String[]
  temperature   Float               @default(0.7)
  maxTokens     Int                 @default(2048)
  enabled       Boolean             @default(true)
  isDefault     Boolean             @default(false)
  priority      Int                 @default(100)
  status        AIModelStatus       @default(UNKNOWN)
  lastCheckedAt DateTime?
  lastLatencyMs Int?
  lastError     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  provider      AIProvider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  routes        AIUsageRouteModel[]
  requestLogs   AIRequestLog[]

  @@unique([providerId, name])
  @@index([enabled, priority, status])
}

model AIUsageRoute {
  id        String              @id @default(uuid()) @db.Uuid
  purpose   AIUsagePurpose      @unique
  strategy  String              @default("PRIORITY_FAILOVER")
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  models    AIUsageRouteModel[]
}

model AIUsageRouteModel {
  id        String       @id @default(uuid()) @db.Uuid
  routeId   String       @db.Uuid
  modelId   String       @db.Uuid
  priority  Int          @default(100)
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  route     AIUsageRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  model     AIModel      @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([routeId, modelId])
  @@index([routeId, enabled, priority])
}

model AIRequestLog {
  id             String          @id @default(uuid()) @db.Uuid
  requestId      String
  providerId     String          @db.Uuid
  modelId        String          @db.Uuid
  purpose        AIUsagePurpose
  userId         String?         @db.Uuid
  status         AIRequestStatus
  latencyMs      Int
  inputTokens    Int?
  outputTokens   Int?
  errorType      String?
  errorMessage   String?
  attemptNo      Int             @default(1)
  fallbackFromId String?         @db.Uuid
  createdAt      DateTime        @default(now())
  provider       AIProvider      @relation(fields: [providerId], references: [id], onDelete: Restrict)
  model          AIModel         @relation(fields: [modelId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([purpose, status, createdAt])
  @@index([providerId, modelId, createdAt])
}

model AIConversation {
  id               String             @id @default(uuid()) @db.Uuid
  learnerProfileId String             @db.Uuid
  teacherStyle     TeacherStyle       @default(GENTLE)
  topic            String
  levelSnapshot    CefrLevel?
  status           ConversationStatus @default(ACTIVE)
  summary          String?
  lastMessageAt    DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  learnerProfile   LearnerProfile     @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  messages         AIMessage[]

  @@index([learnerProfileId, lastMessageAt])
}

model AIMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  role           String
  content        String         @db.Text
  contentZh      String?        @db.Text
  inputTokens    Int?
  outputTokens   Int?
  savedForReview Boolean        @default(false)
  sequence       Int
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, sequence])
}

model Vocabulary {
  id           String                   @id @default(uuid()) @db.Uuid
  word         String
  phonetic     String?
  partOfSpeech String?
  definitionEn String
  level        CefrLevel
  topic        String
  audioUrl     String?
  imageUrl     String?
  status       ContentStatus            @default(PUBLISHED)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  meanings     VocabularyMeaning[]
  examples     VocabularyExample[]
  progress     UserVocabularyProgress[]

  @@unique([word, partOfSpeech])
  @@index([level, topic, status])
}

model VocabularyMeaning {
  id           String     @id @default(uuid()) @db.Uuid
  vocabularyId String     @db.Uuid
  locale       String
  definition   String
  senseOrder   Int        @default(1)
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([vocabularyId, locale, senseOrder])
}

model VocabularyExample {
  id           String     @id @default(uuid()) @db.Uuid
  vocabularyId String     @db.Uuid
  sentence     String
  translation  String?
  collocations String[]
  difficulty   CefrLevel
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
}

model UserVocabularyProgress {
  id                 String           @id @default(uuid()) @db.Uuid
  learnerProfileId   String           @db.Uuid
  vocabularyId       String           @db.Uuid
  state              VocabularyState  @default(NEW)
  firstLearnedAt     DateTime?
  lastReviewedAt     DateTime?
  nextReviewAt       DateTime?
  correctCount       Int              @default(0)
  incorrectCount     Int              @default(0)
  mastery            Float            @default(0)
  easeFactor         Float            @default(2.5)
  intervalDays       Int              @default(0)
  consecutiveCorrect Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  learnerProfile     LearnerProfile   @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  vocabulary         Vocabulary       @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  reviews            ReviewSchedule[]

  @@unique([learnerProfileId, vocabularyId])
  @@index([learnerProfileId, nextReviewAt, state])
}

model ReviewSchedule {
  id          String                 @id @default(uuid()) @db.Uuid
  progressId  String                 @db.Uuid
  scheduledAt DateTime
  completedAt DateTime?
  result      Boolean?
  quality     Int?
  oldInterval Int
  newInterval Int?
  oldEase     Float
  newEase     Float?
  createdAt   DateTime               @default(now())
  progress    UserVocabularyProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, completedAt])
}

model ReadingArticle {
  id               String            @id @default(uuid()) @db.Uuid
  title            String
  body             String            @db.Text
  translation      String?           @db.Text
  level            CefrLevel
  audience         String
  wordCount        Int
  topic            String
  targetVocabulary String[]
  targetGrammar    String[]
  status           ContentStatus     @default(PUBLISHED)
  aiGenerated      Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  questions        ReadingQuestion[]
  progress         ReadingProgress[]

  @@index([level, topic, status])
}

model ReadingQuestion {
  id          String          @id @default(uuid()) @db.Uuid
  articleId   String          @db.Uuid
  type        QuestionType
  prompt      String
  options     Json?
  answerKey   String
  explanation String?
  order       Int
  article     ReadingArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  answers     ReadingAnswer[]

  @@unique([articleId, order])
}

model ReadingProgress {
  id               String          @id @default(uuid()) @db.Uuid
  learnerProfileId String          @db.Uuid
  articleId        String          @db.Uuid
  progressPercent  Int             @default(0)
  currentPosition  Int             @default(0)
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  readingSeconds   Int             @default(0)
  score            Float?
  learnerProfile   LearnerProfile  @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  article          ReadingArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  answers          ReadingAnswer[]

  @@unique([learnerProfileId, articleId])
}

model ReadingAnswer {
  id         String          @id @default(uuid()) @db.Uuid
  progressId String          @db.Uuid
  questionId String          @db.Uuid
  answer     String
  isCorrect  Boolean?
  score      Float?
  feedback   String?
  createdAt  DateTime        @default(now())
  progress   ReadingProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  question   ReadingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model DailyTask {
  id               String           @id @default(uuid()) @db.Uuid
  learnerProfileId String           @db.Uuid
  taskDate         DateTime         @db.Date
  taskType         DailyTaskType
  title            String
  description      String?
  contentRefType   String?
  contentRefId     String?
  estimatedMinutes Int
  status           DailyTaskStatus  @default(PENDING)
  xpReward         Int              @default(10)
  generationReason String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  learnerProfile   LearnerProfile   @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  completions      TaskCompletion[]

  @@index([learnerProfileId, taskDate, status])
}

model TaskCompletion {
  id               String    @id @default(uuid()) @db.Uuid
  taskId           String    @db.Uuid
  attemptNo        Int       @default(1)
  startedAt        DateTime?
  completedAt      DateTime  @default(now())
  durationSeconds  Int
  accuracy         Float?
  earnedXp         Int
  unfinishedReason String?
  needsMakeup      Boolean   @default(false)
  task             DailyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model LearningActivity {
  id               String         @id @default(uuid()) @db.Uuid
  learnerProfileId String         @db.Uuid
  familyId         String         @db.Uuid
  activityType     String
  module           String
  durationSeconds  Int            @default(0)
  score            Float?
  sourceType       String?
  sourceId         String?
  occurredAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  learnerProfile   LearnerProfile @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)

  @@index([learnerProfileId, occurredAt])
  @@index([familyId, occurredAt])
}
