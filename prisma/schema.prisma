model ScenarioLesson {
  id                 String             @id @default(uuid()) @db.Uuid
  category           String
  title              String
  intro              String             @db.Text
  level              CefrLevel
  cultureTips        String[]
  misunderstandings  String[]
  naturalExpressions String[]
  sourceType         ScenarioSourceType @default(ORIGINAL)
  sourceNote         String?
