  suggestions      String            @db.Text
  rewrittenVersion String?           @db.Text
  overallScore     Float
  createdAt        DateTime          @default(now())
  submission       WritingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model PlacementTest {
